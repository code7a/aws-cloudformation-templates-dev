{
    "AWSTemplateFormatVersion": "2010-09-09",
    "Description": "AWS EKS Cluster with Public SSH Access",
    "Parameters": {
        "KeyName": {
            "Description": "EC2 Key Pair Name for SSH access",
            "Type": "AWS::EC2::KeyPair::KeyName"
        },
        "SSHFromIP": {
            "Description": "Your public IP address to allow SSH (Format: x.x.x.x/32)",
            "Type": "String"
        }
    },
    "Resources": {
        "VPC": {
            "Type": "AWS::EC2::VPC",
            "Properties": {
                "CidrBlock": "10.0.0.0/16",
                "EnableDnsSupport": true,
                "EnableDnsHostnames": true
            }
        },
        "InternetGateway": {
            "Type": "AWS::EC2::InternetGateway"
        },
        "VPCGatewayAttachment": {
            "Type": "AWS::EC2::VPCGatewayAttachment",
            "Properties": {
                "InternetGatewayId": { "Ref": "InternetGateway" },
                "VpcId": { "Ref": "VPC" }
            }
        },
        "RouteTable": {
            "Type": "AWS::EC2::RouteTable",
            "Properties": {
                "VpcId": { "Ref": "VPC" }
            }
        },
        "Route": {
            "Type": "AWS::EC2::Route",
            "Properties": {
                "RouteTableId": { "Ref": "RouteTable" },
                "DestinationCidrBlock": "0.0.0.0/0",
                "GatewayId": { "Ref": "InternetGateway" }
            }
        },
        "SubnetA": {
            "Type": "AWS::EC2::Subnet",
            "Properties": {
                "VpcId": { "Ref": "VPC" },
                "CidrBlock": "10.0.0.0/20",
                "AvailabilityZone": { "Fn::Sub": "${AWS::Region}a" },
                "MapPublicIpOnLaunch": true
            }
        },
        "SubnetB": {
            "Type": "AWS::EC2::Subnet",
            "Properties": {
                "VpcId": { "Ref": "VPC" },
                "CidrBlock": "10.0.16.0/20",
                "AvailabilityZone": { "Fn::Sub": "${AWS::Region}b" },
                "MapPublicIpOnLaunch": true
            }
        },
        "SubnetARouteTableAssociation": {
            "Type": "AWS::EC2::SubnetRouteTableAssociation",
            "Properties": {
                "RouteTableId": { "Ref": "RouteTable" },
                "SubnetId": { "Ref": "SubnetA" }
            }
        },
        "SubnetBRouteTableAssociation": {
            "Type": "AWS::EC2::SubnetRouteTableAssociation",
            "Properties": {
                "RouteTableId": { "Ref": "RouteTable" },
                "SubnetId": { "Ref": "SubnetB" }
            }
        },
        "SecurityGroup": {
            "Type": "AWS::EC2::SecurityGroup",
            "Properties": {
                "VpcId": { "Ref": "VPC" },
                "GroupDescription": "Allow SSH Access",
                "SecurityGroupIngress": [
                    {
                        "IpProtocol": "tcp",
                        "FromPort": 22,
                        "ToPort": 22,
                        "CidrIp": { "Ref": "SSHFromIP" }
                    }
                ]
            }
        },
        "EKSClusterRole": {
            "Type": "AWS::IAM::Role",
            "Properties": {
                "AssumeRolePolicyDocument": {
                    "Version": "2012-10-17",
                    "Statement": [{
                        "Effect": "Allow",
                        "Principal": { "Service": "eks.amazonaws.com" },
                        "Action": "sts:AssumeRole"
                    }]
                },
                "ManagedPolicyArns": [
                    "arn:aws:iam::aws:policy/AmazonEKSClusterPolicy"
                ]
            }
        },
        "EKSCluster": {
            "Type": "AWS::EKS::Cluster",
            "Properties": {
                "Name": "my-eks-cluster",
                "RoleArn": { "Fn::GetAtt": ["EKSClusterRole", "Arn"] },
                "ResourcesVpcConfig": {
                    "SubnetIds": [
                        { "Ref": "SubnetA" },
                        { "Ref": "SubnetB" }
                    ]
                }
            }
        },
        "EKSNodeRole": {
            "Type": "AWS::IAM::Role",
            "Properties": {
                "AssumeRolePolicyDocument": {
                    "Version": "2012-10-17",
                    "Statement": [{
                        "Effect": "Allow",
                        "Principal": { "Service": "ec2.amazonaws.com" },
                        "Action": "sts:AssumeRole"
                    }]
                },
                "ManagedPolicyArns": [
                    "arn:aws:iam::aws:policy/AmazonEKSWorkerNodePolicy",
                    "arn:aws:iam::aws:policy/AmazonEC2ContainerRegistryReadOnly",
                    "arn:aws:iam::aws:policy/AmazonEKS_CNI_Policy"
                ]
            }
        },
        "EKSNodegroup": {
            "Type": "AWS::EKS::Nodegroup",
            "Properties": {
                "ClusterName": { "Ref": "EKSCluster" },
                "NodeRole": { "Fn::GetAtt": ["EKSNodeRole", "Arn"] },
                "Subnets": [
                    { "Ref": "SubnetA" },
                    { "Ref": "SubnetB" }
                ],
                "InstanceTypes": ["t3.medium"],
                "AmiType": "AL2_x86_64",
                "RemoteAccess": {
                    "Ec2SshKey": { "Ref": "KeyName" },
                    "SourceSecurityGroups": [{ "Ref": "SecurityGroup" }]
                }
            }
        }
    },
    "Outputs": {
        "ClusterName": {
            "Description": "EKS Cluster Name",
            "Value": { "Ref": "EKSCluster" }
        },
        "NodeGroupName": {
            "Description": "EKS Nodegroup Name",
            "Value": { "Ref": "EKSNodegroup" }
        },
        "VPCId": {
            "Description": "VPC ID",
            "Value": { "Ref": "VPC" }
        },
        "SubnetAId": {
            "Description": "Subnet A ID",
            "Value": { "Ref": "SubnetA" }
        },
        "SubnetBId": {
            "Description": "Subnet B ID",
            "Value": { "Ref": "SubnetB" }
        }
    }
}
